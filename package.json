{
  "name": "@c9up/bay",
  "version": "0.1.5",
  "description": "Queue — pluggable job-queue contract with memory + Redis drivers for the Ream framework",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./provider": {
      "types": "./src/BayProvider.ts",
      "import": "./src/BayProvider.ts"
    },
    "./services/main": {
      "types": "./src/services/main.ts",
      "import": "./src/services/main.ts"
    },
    "./testing": {
      "types": "./src/testing/FakeQueue.ts",
      "import": "./src/testing/FakeQueue.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "lint": "biome check src/",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@c9up/ream": "^0.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "files": [
    "src",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./provider": {
        "types": "./dist/BayProvider.d.ts",
        "import": "./dist/BayProvider.js"
      },
      "./services/main": {
        "types": "./dist/services/main.d.ts",
        "import": "./dist/services/main.js"
      },
      "./testing": {
        "types": "./dist/testing/FakeQueue.d.ts",
        "import": "./dist/testing/FakeQueue.js"
      }
    },
    "access": "public"
  },
  "peerDependenciesMeta": {
    "@c9up/ream": {
      "optional": true
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/C9up/bay.git"
  }
}
